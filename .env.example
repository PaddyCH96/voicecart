# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/voicecart"

# ─── Auth ────────────────────────────────────────────────
# At least 32 characters, must not be a placeholder/default value
JWT_SECRET="generate-a-random-64-char-string-here-do-not-use-this-exact-value!!"
# Shared secret for internal endpoint auth (process-ad, retry-queue, render/process)
CRON_SECRET="generate-a-random-cron-secret-here"

# ─── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── ElevenLabs ──────────────────────────────────────────
ELEVENLABS_API_KEY="..."

# ─── Cloudinary ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# ─── Razorpay ────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_..."
RAZORPAY_KEY_SECRET="..."
RAZORPAY_WEBHOOK_SECRET="..."
RAZORPAY_PRO_PLAN_ID="plan_..."   # Razorpay plan ID for Pro subscription
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_..."  # Same as RAZORPAY_KEY_ID, public

# ─── MSG91 (SMS OTP) ────────────────────────────────────
MSG91_AUTH_KEY="..."
MSG91_TEMPLATE_ID="..."  # MSG91 OTP template ID

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379
# Optional: If using Upstash REST API instead of Redis TCP
# UPSTASH_REDIS_REST_URL="https://...upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3003"
NODE_ENV="development"
